# Template for the server's ~/BoslaPipeline/pipeline.env (EnvironmentFile for the
# bosla-pipeline systemd service). Copy to pipeline.env on the server and fill in
# secrets. NOT deployed/overwritten by CI (the deploy excludes pipeline.env).

# Runtime profile
FREE_HF_MODE=false
ENABLE_EXTERNAL_SCRAPERS=false   # YouTube-only (no Udemy/Coursera)
SKIP_GLOBAL_DRIVER_INIT=true
INFERENCE_TRANSPORT=socketio     # socketio (this server) | webpubsub (ACI worker)
PYTHONUNBUFFERED=1

# Auth — these are bypass settings for the localhost test driver ONLY.
# For any public exposure: set REQUIRE_SOCKET_TOKEN=true, remove ALLOW_DEV_AUTH_BYPASS,
# set PIPELINE_SHARED_SECRET, and front with TLS.
REQUIRE_SOCKET_TOKEN=false
ALLOW_DEV_AUTH_BYPASS=true
# PIPELINE_SHARED_SECRET=

# YouTube — yt-dlp is bot-gated on datacenter IPs, so the Data API is required
# for real fetches. Set DISABLE_YOUTUBE_API=false and provide at least one key.
DISABLE_YOUTUBE_API=true
# YOUTUBE_API_KEY_1=
# YOUTUBE_API_KEY_2=

# Pipeline logs for the admin dashboard (ACI worker path):
# the worker buffers its logs into a TTL'd Cosmos container and the .NET admin
# API serves them to the Pipeline Monitor. These come from the ACI dispatcher
# (COSMOS_* + COSMOS_LOGS_CONTAINER), so they aren't set here — but the per-job
# log-doc TTL is tunable on the worker:
# PIPELINE_LOGS_TTL_SECONDS=86400   # how long a job's logs survive in Cosmos
